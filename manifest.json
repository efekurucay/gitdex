{
  "manifest_version": 3,
  "name": "GitHub to NotebookLM",
  "version": "1.0.0",
  "description": "Clone any public GitHub repo, convert all files to .txt with file path headers, merge subdirectory files, and import to NotebookLM in one click.",
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://notebooklm.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
